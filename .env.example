AGY_MCP_MODE=safe
AGY_MCP_ALLOWED_ROOTS=["/path/to/your/projects"]
AGY_MCP_DEFAULT_TIMEOUT_S=300
AGY_MCP_MAX_OUTPUT_BYTES=2000000
AGY_MCP_MAX_RUNS=50
AGY_MCP_FORCE_SANDBOX_IN_SAFE_MODE=true
AGY_MCP_FIX_ANTIGRAVITY_MCP_CONFIG=true

# The lists below only apply in permissive mode. In safe mode, env and extra_args are rejected.
AGY_MCP_ALLOW_ENV_KEYS=[]
AGY_MCP_ALLOW_EXTRA_ARGS=[]

# Persistence layer (editable AGENTS.md, PROJECTS.md, MEMORY.md)
# Stored under ~/.open-cli-router/<provider>/
AGY_MCP_PERSISTENCE_ENABLED=true
AGY_MCP_PERSISTENCE_BASE_DIR=~/.open-cli-router
AGY_MCP_PERSISTENCE_MAX_FILE_BYTES=524288
AGY_MCP_PERSISTENCE_BACKUP_ON_WRITE=false
AGY_MCP_PERSISTENCE_SEED_TEMPLATES=true

# Quota tracking (optional)
AGY_MCP_QUOTA_ACTIVE_MODEL=unknown
AGY_MCP_QUOTA_TIER=unknown
